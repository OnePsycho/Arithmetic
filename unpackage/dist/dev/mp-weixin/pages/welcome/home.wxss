.page {
  height: 100vh;
  position: relative;
  padding-bottom: 150rpx;
  font-family: 'myFont';
  font-weight: 200;
}
.page .logo {
  width: 100%;
}
.page .logo image {
  width: 80%;
  margin-left: 10%;
  margin-top: 20px;
}
.page .logo .logo-image {
  width: 40%;
  margin-left: 30%;
  margin-top: 20%;
}
.page .btn-start {
  position: absolute;
  width: 100%;
  bottom: 10%;
  left: 0;
}
.page .btn-start image {
  width: 40%;
  margin-left: 30%;
  border: 1px solid #d1d1d1;
  margin-bottom: 30rpx;
}
.page .btn-start-txt {
  width: 60%;
  margin-left: 20%;
  border: 2px solid #e0e0e0;
  text-align: center;
  height: 150rpx;
  display: -webkit-box;
  display: -webkit-flex;
  display: flex;
  -webkit-box-pack: center;
  -webkit-justify-content: center;
          justify-content: center;
  -webkit-box-align: center;
  -webkit-align-items: center;
          align-items: center;
  font-size: 32px;
  color: #7a7a7a;
}
.type-item {
  padding: 20rpx 0;
  margin: 20rpx 0;
  font-size: 18px;
}

