
.page {
	height: 100vh;
}
.bg-image{
	width: 100% !important;
}
.card-swiper{
	margin-top: -25%;
}
.tower-swiper .tower-item {
	-webkit-transform: scale(calc(0.5 + var(--index) / 10));
	        transform: scale(calc(0.5 + var(--index) / 10));
	margin-left: calc(var(--left) * 100rpx - 150rpx);
	z-index: var(--index);
}

